APP_NAME="NLC Document Intelligence API"
ENVIRONMENT="development"
DATABASE_URL="sqlite:///./database/nlc.db"


OPENROUTER_API_KEY=""

GROQ_API_KEY=""

HUGGINGFACE_API_KEY=""

REQUIRE_HTTPS=false
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
ALLOWED_HOSTS=["localhost","127.0.0.1","api","testserver"]
CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
PROCESSING_MAX_WORKERS=10
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
UPLOAD_MAX_TOTAL_SIZE_BYTES=31457280
